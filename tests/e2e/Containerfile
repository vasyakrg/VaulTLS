# Stage 1: Build dependencies
FROM python:3.14-slim-bookworm AS builder

ENV DEBIAN_FRONTEND=noninteractive

# Force apt over IPv4: some Docker build networks advertise IPv6 but cannot
# route it, so apt hangs on deb.debian.org's AAAA records. This config also
# applies to `playwright install --with-deps`, which shells out to apt.
RUN echo 'Acquire::ForceIPv4 "true";' > /etc/apt/apt.conf.d/99force-ipv4

# Install OS dependencies for Playwright (build stage only)
RUN apt-get update && apt-get install -y \
    curl wget unzip gnupg \
    libglib2.0-0 libnss3 libgconf-2-4 \
    libfontconfig1 libxss1 libasound2 \
    libxtst6 libgtk-3-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

RUN python -m playwright install --with-deps

# Stage 2: Final runtime image
FROM builder

WORKDIR /app

# Copy only app code
COPY . .

CMD ["pytest"]